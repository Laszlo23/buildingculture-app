# Copy to /etc/nginx/sites-available/ and symlink sites-enabled.
# Replace SSL paths after: sudo certbot certonly --nginx -d app.buildingculture.capital
# Adjust root if your deploy path differs.

upstream buildingculture_api {
    keepalive 32;
    server 127.0.0.1:3001;
}

server {
    listen 80;
    listen [::]:80;
    server_name app.buildingculture.capital;

    # After certificates exist, Certbot will add SSL blocks or use redirect-only HTTP.
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name app.buildingculture.capital;

    # Update these paths after certbot (or use certbot --nginx to manage):
    ssl_certificate     /etc/letsencrypt/live/app.buildingculture.capital/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/app.buildingculture.capital/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    root /var/www/buildingculture/app/dist;
    index index.html;

    gzip on;
    gzip_types text/css application/javascript application/json image/svg+xml;

    location /api/ {
        proxy_pass         http://buildingculture_api;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    location = /health {
        proxy_pass         http://buildingculture_api;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
